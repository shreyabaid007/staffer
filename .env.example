# Identity tokenization — HMAC key for candidate_id (AD-067). Required by `dsm ingest`
# (silver). Must stay constant: the same key → the same candidate_id across runs/snapshots;
# changing it re-keys every candidate. Use a random secret; keep it out of git (.env is ignored).
DSM_CANDIDATE_ID_KEY=

# OpenRouter (reasoning LLM)
OPENROUTER_API_KEY=

# Modal (serverless embeddings)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
