__pycache__/
*.pyc
.DS_Store
.venv/
.env
data/.cache/*
!data/.cache/.gitkeep
# Raw inputs and bronze layer are PII-dense — never commit (a-001 L-LAYOUT-3)
data/raw/demand/*
!data/raw/demand/.gitkeep
data/raw/supply/*
!data/raw/supply/.gitkeep
data/raw/resumes/*
!data/raw/resumes/.gitkeep
data/raw/feedback/*
!data/raw/feedback/.gitkeep
data/bronze/blobs/sha256/*
!data/bronze/blobs/sha256/.gitkeep
data/bronze/records/*
!data/bronze/records/.gitkeep
data/bronze/manifest.jsonl
# Silver layer is PII-dense (raw_text holds resume/feedback bodies) — never commit (SW-2)
data/silver/records/*
!data/silver/records/.gitkeep
# Gold carries vault refs + verbatim evidence quotes (may include client orgs) — never commit (GS-3)
data/gold/*
!data/gold/.gitkeep

# Enrich extraction cache + web ingest-job logs (c-011, AD-XXX/AD-XXY) — derived, PII-dense
data/enrich_cache/*
!data/enrich_cache/.gitkeep
data/ingest_jobs/*
!data/ingest_jobs/.gitkeep
# Index is a rebuildable artifact: derived (PII-free) vectors + metadata in Milvus Lite (NF-5)
data/index/*
!data/index/.gitkeep
# Identity vault: raw name/email keyed by candidate_id (AD-098) — never commit. Plaintext this
# slice; encryption/retention/purge deferred to AD-068.
data/identity/
# Decision capture log: candidate_id-keyed, but carries operator-entered free-text reasons that
# may name a consultant — never commit (c-008/AD-XXX).
data/decisions/*
!data/decisions/.gitkeep
# Compiled DSPy artefacts (MIPROv2 output — optimised prompt text, not code)
artifacts/
*.egg-info/
dist/
.mypy_cache/
.pyright/
.ruff_cache/
.idea/
.claude/lane
